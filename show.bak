<main>
<h2 style="font-family: sans-serif  , Calibri ; color: red " >Our Slide Show</h2>

  <div class="gotlogo">

  <!-- <h1>Slide Show</h1>> -->


  <p style="text-decoration: none; text-shadow: 0px 0px 0px ; color: yellow" ><strong>Look for the below line of text in the html file. The text <span style="color: red;">- ('slide')[0] -</span> makes it happen
   </strong></p>

<p>
  <code><strong>
  document.getElementsByName('slide')[0].src = images[i];
  </strong></code>
</p>

    <!-- <img src="./images/black.jpg" alt="GOT"> -->
  </div>
  <div class="slider" name='w'>
    <img name="slide" height="150" width="300">
  </div>
  <p>
    <br>
  </p>
</body>


<script>

// Source - https://stackoverflow.com/a/55664861
// Posted by jasinth premkumar, modified by community. See post 'Timeline' for change history
// Retrieved 2026-04-10, License - CC BY-SA 4.0

var i = 0;                        // Start Point
var images = [];        // Images Array
var time = 4000;        // Time Between Switch

// Image List
//<!-- images[0] = "https://www.w3schools.com/html/pic_trulli.jpg"; -->
//<!-- images[1] = "https://www.w3schools.com/html/img_girl.jpg"; -->
//<!-- images[2]= "./images/fun.jpg"; -->
// Image List ".\images\.jpg";
images[0] = "./images/fun.jpg";
images[1] = "./images/installation.jpg";
images[2] = "./images/maintenance.jpg";
images[3] = "./images/pool.jpg";
images[4] = "./images/pump.jpg";
images[5] = "./images/swim.jpg";
images[6] = "./images/gang5.png";


// Change Image
function changeImg(){
  document.getElementsByName('slide')[0].src = images[i];

  // Check If Index Is Under Max
  if (i < images.length - 1){
    // Add 1 to Index
    i++;
  } else {
    // Reset Back To O
    i = 0;
  }

  // Run function every x seconds
  setTimeout("changeImg()", time);
}

// Run function when page loads
window.onload = changeImg;

</script>




